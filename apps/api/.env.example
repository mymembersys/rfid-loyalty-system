# API server
PORT=4000
NODE_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# JWT
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=12h

# PostgreSQL
DATABASE_URL=postgres://rfid_user:rfid_pass@localhost:5432/rfid_loyalty

# Loyalty defaults (can be overridden per service line in DB)
DEFAULT_STAMP_COOLDOWN_MINUTES=720
